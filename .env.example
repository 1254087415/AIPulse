# AIPulse 环境变量配置
# 复制本文件为 .env 后填入真实值

# SQLite 数据库路径（默认使用项目目录下的 data/aipulse.db）
DATABASE_URL=sqlite+aiosqlite:///data/aipulse.db

# OpenAI / Kimi / OpenRouter API 配置（用于视频总结、摘要生成）
# 默认使用 Kimi Code（OpenAI 兼容接口）
LLM_PROVIDER=openai
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=kimi-code

# 文本向量化模型（v0.2 启用）
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMBEDDING_MODEL=text-embedding-3-small

# 飞书机器人 Webhook（用于推送通知）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxx
FEISHU_SECRET=

# 微信公众号模板消息（用于博主更新提醒和处理完成通知）
WECHAT_APPID=wx-xxxxxxxxxxxxxxxx
WECHAT_APPSECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WECHAT_TEMPLATE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WECHAT_OPENID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Obsidian 配置
OBSIDIAN_VAULT_PATH=/Users/xxx/Documents/Obsidian Vault
OBSIDIAN_ARCHIVE_FOLDER=AIPulse

# 文件下载目录（本地视频/音频保留在此，不进入 git）
DATA_DIR=./data
DOWNLOAD_DIR=./data/downloads

# API 鉴权令牌（留空表示不启用，仅用于开发环境；生产环境必须设置）
AIPULSE_API_TOKEN=
