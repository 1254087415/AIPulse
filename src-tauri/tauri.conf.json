{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIPulse",
  "version": "0.1.0",
  "identifier": "com.aipulse.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd .. && ./scripts/sync-sidecar-resources.sh && cd frontend && npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "12.0"
    },
    "resources": {
      "resources/aipulse": "aipulse"
    }
  },
  "plugins": {
    "shell": {
      "open": "^(https?://|obsidian://open\\?vault=)"
    }
  }
}
